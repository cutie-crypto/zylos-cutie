{
  "name": "@cutie-crypto/zylos-cutie",
  "version": "2.1.0",
  "description": "Cutie KOL agent component for Zylos / COCO runtime — Claude / Codex CLI under SRT sandbox",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cutie-pair": "dist/cli/pair.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "ecosystem.config.cjs",
    "hooks",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node --import tsx/esm scripts/smoke.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cutie",
    "zylos",
    "coco",
    "kol",
    "ai-agent",
    "sandbox"
  ],
  "author": "Cutie Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cutie-crypto/zylos-cutie.git"
  },
  "homepage": "https://github.com/cutie-crypto/zylos-cutie#readme",
  "bugs": {
    "url": "https://github.com/cutie-crypto/zylos-cutie/issues"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "0.0.50",
    "@cutie-crypto/connector-core": "^0.3.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
